# ── Supabase (읽기 전용으로 충분) ─────────────────────────────
# 앱과 동일한 프로젝트. 공개 콘텐츠만 읽으므로 anon key로 충분하지만,
# RLS로 막혀 있다면 service_role key를 넣으세요.
SUPABASE_URL=
SUPABASE_KEY=

# ── R2 공개 URL prefix ────────────────────────────────────────
# 이 prefix로 시작하는 미디어만 "업로드 가능한 R2 파일"로 판단합니다.
# 앱의 VITE_R2_PUBLIC_URL 과 동일한 값 (예: https://cdn.mmemory.cloud)
R2_PUBLIC_URL=

# ── X (트위터) API — OAuth 1.0a User Context ──────────────────
# X 개발자 포털 > 앱 > Keys and tokens 에서 발급.
# 앱 권한은 반드시 "Read and write" 여야 게시가 됩니다.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── 옵션 ──────────────────────────────────────────────────────
# 특정 날짜로 강제 실행(테스트용). 비우면 오늘(Asia/Seoul) 기준.
# DATE=2026-07-14
